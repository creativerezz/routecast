{
  "name": "routecast",
  "version": "0.1.0",
  "description": "The cost intelligence layer for AI agents — an analyzer, not a gateway. Forecast LLM spend with variance bands, get routing recommendations, attribute reasoning tokens, and catch pricing cliffs.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "routecast": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@routecast/core": "workspace:*",
    "@routecast/mcp": "workspace:*",
    "@routecast/pricing": "workspace:*",
    "commander": "^14.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "tsdown": "^0.12.0"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/creativerezz/routecast.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "llm",
    "cost",
    "optimizer",
    "tokens",
    "forecast",
    "routing",
    "mcp",
    "agents",
    "claude-code",
    "finops"
  ]
}
